{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start OpenOCD",
      "type": "shell",
      "command": "source ${config:idf.currentSetup}/export.sh && idf.py openocd",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)(Listening on port 3333|starting gdb server)(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Listening on port 3333|starting gdb server"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
